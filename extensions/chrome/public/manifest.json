{
  "manifest_version": 3,
  "name": "LuminexLabs",
  "version": "1.0.0",
  "description": "ดึงข้อมูล TikTok Shop & Creator Center อัตโนมัติ",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "cookies"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.tiktokshop.com/*",
    "https://creator.tiktok.com/*",
    "https://*.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tiktok.com/*",
        "https://*.tiktokshop.com/*",
        "https://creator.tiktok.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
